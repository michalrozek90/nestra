{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["expo/tsconfig.base", "@nestra/tsconfig/react-native.json"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "app.config.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
