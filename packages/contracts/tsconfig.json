{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@nestra/tsconfig/base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ES2023"
  },
  "include": ["src/**/*.ts"]
}
